{
    "boot_config": {
        "cpus": 8,
        "memory": "16384M",
        "bios": "../OVMF.fd",
        "acpi_tables": "acpi_tables.bin",
        "qemu": {
            "machine": "q35,kernel_irqchip=split,memory-backend=mem0,smm=off,pic=off",
            "cpu": "Skylake-Server,phys-bits=46",
            "accel": "tcg",
            "globals": [
                "q35-pcihost.pci-hole64-size=4096G",
                "vfio-pci.x-balloon-allowed=false",
                "vfio-pci.x-no-mmap=false"
            ],
            "objects": [
                "memory-backend-ram,id=mem0,size=16384M"
            ],
            "netdevs": [
                "hubport,id=net0,hubid=0"
            ],
            "devices": [
                "e1000,netdev=net0,bus=pcie.0,addr=0x2,romfile=",
                "vhost-vsock-pci,guest-cid=99",
                "virtio-scsi-pci,id=scsi0,disable-legacy=on,iommu_platform=true",
                "virtio-scsi-pci,id=scsi1,disable-legacy=on,iommu_platform=true",
                "virtio-scsi-pci,id=scsi2,disable-legacy=on,iommu_platform=true"
            ],
            "fw_cfg": []
        }
    },
    "direct": {
        "kernel": "/dev/null",
        "initrd": "/dev/null",
        "cmdline": ""
    }
}
